# Cấu hình môi trường cho BloodCare AI
# Copy file này thành file .env và điền các giá trị thực tế của bạn. KHÔNG commit file .env lên Git.

# Khóa API Gemini chính thức từ Google AI Studio (bắt đầu bằng AIzaSy...)
GEMINI_API_KEY=AIzaSyYourGeminiAPIKeyHere

# Khóa Session Secret của ứng dụng Flask
SECRET_KEY=bloodcare_secret_session_key_2026
